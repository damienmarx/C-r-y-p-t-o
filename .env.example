# Node Environment
NODE_ENV=development
PORT=3000

# Database Configuration (VPS)
DATABASE_URL=postgresql://user:password@localhost:5432/osrs_crypto
REDIS_URL=redis://localhost:6379

# Domain and Routing (Cloudflare Tunnels)
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_TOKEN=
